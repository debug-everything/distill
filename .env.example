# Runtime environment: local-pc | local-mac
RUNTIME_ENV=local-pc

# Local AI (Ollama on Mac M3 Pro)
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_CHAT_HEAVY=llama3.1:8b        # llama3.1:8b (Mac M3 Pro) | qwen2.5:14b (PC RTX 5060 Ti)
LOCAL_CHAT_LIGHT=llama3.1:8b
LOCAL_EMBED_MODEL=nomic-embed-text

# LLM routing: auto (local-first, cloud fallback) | cloud (force cloud) | local (force local, fail if Ollama down)
LLM_MODE_LIGHT=auto      # embed, tag_topics, score_quality
LLM_MODE_HEAVY=auto      # summarize, rag_answer

# Cloud fallback (only used when Ollama unavailable or mode=cloud)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
CLOUD_CHAT_MODEL=gpt-4o-mini
CLOUD_CHAT_FALLBACK=claude-haiku-3-5
CLOUD_EMBED_MODEL=text-embedding-3-small

# Database — local Docker or remote Neon
# Local:  DATABASE_URL=postgresql+asyncpg://<user>:<pass>@localhost:5432/<db>
# Neon:   DATABASE_URL=postgresql+asyncpg://<user>:<pass>@<host>/<db>
DATABASE_URL=

# Local Docker Postgres (used by docker-compose.yml)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
